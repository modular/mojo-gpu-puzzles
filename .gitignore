# pixi environments
.pixi
*.egg-info
*.lock
# misc
*.DS_Store
__pycache__

# Book artifacts
book/book
book/html
book/html-*

# Downloaded offline-build assets (fetched on demand, see
# scripts/fetch_offline_assets.sh); not checked into version control. The
# directory itself must still exist for the default (online) build — mdbook's
# extra-files fails hard on a missing path — so keep .gitkeep tracked.
book/theme/vendor-cache/*
!book/theme/vendor-cache/.gitkeep

book/src/puzzle_*/media/images/
book/src/puzzle_*/media/texts/
book/src/puzzle_*/media/Tex/
book/src/puzzle_*/media/videos/*/partial_movie_files/
book/src/puzzle_*/media/videos/*/*.gif
book/src/puzzle_*/media/*.gif

# Vercel
.vercel

# Mojo artifacts
*.mojoc
*.mojopkg

# rules
.cursor/
.claude/
.agents/
.agent/

# llvm
*.ll

# Specific to this project
solutions/p16/p16_optimized
*.nsys-rep
*.ncu-rep
*.qdrep
*.sqlite
*.txt
**/p*/p*_profiler
